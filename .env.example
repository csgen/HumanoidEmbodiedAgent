# Cloud OpenAI-compatible calls read llm_api_key first, then OPENAI_API_KEY.
llm_api_key=
base_url=
INPUT_MODE=webcam
RUN_MODE=oneshot
# Live Linux webcam: WEBCAM_SOURCE=0
# SSH-tunneled remote camera: WEBCAM_SOURCE=http://127.0.0.1:5000/video_feed
WEBCAM_SOURCE=debug_video_samples/waving__portrait_guy_waving_hand__QvJaZ0h94Eo.mp4
FRAMEBUFFER_BACKEND=auto
FRAMEBUFFER_WIDTH=1280
FRAMEBUFFER_HEIGHT=720
VLM_BACKEND=openai
LOCAL_VLM_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
LOCAL_VLM_LOAD_IN_4BIT=1
VLM_MODEL=gpt-4o
ONE_SHOT_BUFFER_TIMEOUT=8
ONE_SHOT_VLM_TIMEOUT=120
# Benchmark: 0. Visual demo: 5 gives a short post-action viewing window.
ONE_SHOT_POST_EXECUTION_SECONDS=0
VLM_SCENARIO_HINT=
