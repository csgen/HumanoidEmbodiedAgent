#!/bin/bash
#PBS -N ml_backtest_parallel
#PBS -q normal
#PBS -l select=1:ncpus=36:ngpus=1:mem=240GB
#PBS -l walltime=02:00:00
#PBS -j oe
#PBS -o /nfs/home/svu/e1538626/projects-sam/FinSight-QuantLab/logs/ml_backtest_parallel.log

################################################################################
# MASSIVELY PARALLEL ML BACKTESTING
# Runs all 8 strategies in parallel using background jobs
# Each strategy gets ~4 CPU cores, all share 1 GPU (batched inference is fast)
################################################################################

set -euo pipefail

# ============================================================================
# CONFIGURATION
# ============================================================================

PROJECT_NAME="FinSight-QuantLab"
PROJECT_DIR="/nfs/home/svu/e1538626/projects-sam/${PROJECT_NAME}"
VENV_PATH="$HOME/.venvs/finsight-tf211-cuda117"
SCRATCH_DIR="/scratch/${PBS_JOBID}"

LOG_DIR="${PROJECT_DIR}/logs"
RESULTS_DIR="${PROJECT_DIR}/results/ml_backtest"

mkdir -p "${LOG_DIR}"
mkdir -p "${RESULTS_DIR}"

# ============================================================================
# ENVIRONMENT SETUP
# ============================================================================

echo "========================================================================"
echo "ML BACKTESTING - PARALLEL EXECUTION"
echo "========================================================================"
echo "Job ID: ${PBS_JOBID}"
echo "Host: $(hostname)"
echo "Start: $(date)"
echo "Project: ${PROJECT_DIR}"
echo "Scratch: ${SCRATCH_DIR}"
echo "========================================================================"

# Load modules
module purge
module load miniconda3/py39_4.12.0
module load cuda/11.7.0
module load gcc/8.2.0

# Activate venv
source "${VENV_PATH}/bin/activate"
echo "[ENV] Activated: $(which python)"
echo "[ENV] Python: $(python --version)"

# Threading configuration (36 cores / 8 strategies = 4.5 cores each)
export OMP_NUM_THREADS=4
export MKL_NUM_THREADS=4
export OPENBLAS_NUM_THREADS=4
export TF_NUM_INTRAOP_THREADS=4
export TF_NUM_INTEROP_THREADS=1
export TF_FORCE_GPU_ALLOW_GROWTH=true

# GPU check
echo ""
echo "========================================================================"
echo "GPU INFO"
echo "========================================================================"
nvidia-smi --query-gpu=name,driver_version,memory.total --format=csv
echo ""

# CPU check
echo "========================================================================"
echo "CPU INFO"
echo "========================================================================"
lscpu | grep -E "Model name|Thread|Core|Socket"
echo ""

# Stage code to scratch
echo "========================================================================"
echo "STAGING CODE TO SCRATCH"
echo "========================================================================"
mkdir -p "${SCRATCH_DIR}"
rsync -av --exclude='.*' --exclude='__pycache__' \
    "${PROJECT_DIR}/src" \
    "${PROJECT_DIR}/config.py" \
    "${PROJECT_DIR}/data" \
    "${PROJECT_DIR}/results" \
    "${SCRATCH_DIR}/"
echo "[STAGED] Code copied to ${SCRATCH_DIR}"
echo ""

cd "${SCRATCH_DIR}"

# ============================================================================
# PARALLEL STRATEGY EXECUTION
# ============================================================================

echo "========================================================================"
echo "LAUNCHING PARALLEL BACKTESTS"
echo "========================================================================"
echo "Strategy allocation: 8 strategies × 4 cores = 32/36 cores used"
echo "GPU: Shared across all strategies (batched inference)"
echo ""

# Create array to track PIDs
declare -a PIDS
declare -a STRATEGIES

# Define all strategies
ALL_STRATEGIES=(
    "distance"
    "cointegration"
    "timeseries"
    "clustering"
    "siamese"
    "xgboost"
    "lstm_spread"
    "transformer"
)

# Launch each strategy in background
for STRATEGY in "${ALL_STRATEGIES[@]}"; do
    echo "[LAUNCH] Starting ${STRATEGY} in background..."

    STRATEGY_LOG="${LOG_DIR}/backtest_${STRATEGY}.log"

    python src/ml_backtest/backtest_single_strategy.py \
        --strategy "${STRATEGY}" \
        > "${STRATEGY_LOG}" 2>&1 &

    PID=$!
    PIDS+=($PID)
    STRATEGIES+=("${STRATEGY}")

    echo "  [PID] ${STRATEGY}: ${PID}"

    # Small delay to stagger GPU initialization
    sleep 2
done

echo ""
echo "========================================================================"
echo "WAITING FOR COMPLETION"
echo "========================================================================"
echo "Launched ${#PIDS[@]} parallel jobs"
echo "PIDs: ${PIDS[@]}"
echo ""

# Monitor progress
declare -a FAILED
declare -a SUCCESS

for i in "${!PIDS[@]}"; do
    PID="${PIDS[$i]}"
    STRATEGY="${STRATEGIES[$i]}"

    echo "[WAIT] ${STRATEGY} (PID: ${PID})..."

    if wait "${PID}"; then
        echo "  ✓ ${STRATEGY} completed successfully"
        SUCCESS+=("${STRATEGY}")
    else
        EXIT_CODE=$?
        echo "  ✗ ${STRATEGY} failed (exit code: ${EXIT_CODE})"
        FAILED+=("${STRATEGY}")
    fi
done

echo ""
echo "========================================================================"
echo "AGGREGATING RESULTS"
echo "========================================================================"

# Copy results back from scratch
rsync -av "${SCRATCH_DIR}/results/ml_backtest/" "${RESULTS_DIR}/"
echo "[COPIED] Results to ${RESULTS_DIR}"

# Generate summary
SUMMARY_FILE="${RESULTS_DIR}/execution_summary.txt"
{
    echo "ML Backtesting Execution Summary"
    echo "================================="
    echo "Job ID: ${PBS_JOBID}"
    echo "Completed: $(date)"
    echo ""
    echo "Successful (${#SUCCESS[@]}):"
    for s in "${SUCCESS[@]}"; do
        echo "  ✓ ${s}"
    done
    echo ""
    echo "Failed (${#FAILED[@]}):"
    if [ ${#FAILED[@]} -eq 0 ]; then
        echo "  (none)"
    else
        for s in "${FAILED[@]}"; do
            echo "  ✗ ${s}"
        done
    fi
    echo ""
    echo "Results directory: ${RESULTS_DIR}"
    echo "Individual logs: ${LOG_DIR}/backtest_*.log"
} > "${SUMMARY_FILE}"

cat "${SUMMARY_FILE}"

# ============================================================================
# CREATE COMBINED SUMMARY TABLE
# ============================================================================

echo ""
echo "========================================================================"
echo "CREATING SUMMARY TABLE"
echo "========================================================================"

python -c "
import pandas as pd
from pathlib import Path

results_dir = Path('${RESULTS_DIR}')
strategies = [s for s in ${SUCCESS[@]@Q}]

summary_rows = []
for strategy in strategies:
    metrics_file = results_dir / f'{strategy}_metrics.csv'
    if metrics_file.exists():
        metrics = pd.read_csv(metrics_file)
        metrics_dict = dict(zip(metrics['metric'], metrics['value']))

        summary_rows.append({
            'Strategy': strategy.replace('_', ' ').title(),
            'Sharpe': metrics_dict.get('sharpe', float('nan')),
            'CAGR': metrics_dict.get('cagr', float('nan')),
            'AnnVol': metrics_dict.get('ann_vol', float('nan')),
            'MaxDD': metrics_dict.get('max_dd', float('nan')),
            'Turnover': metrics_dict.get('turnover', float('nan'))
        })

if summary_rows:
    summary_df = pd.DataFrame(summary_rows)
    summary_df = summary_df.sort_values('Sharpe', ascending=False)

    # Save CSV
    summary_df.to_csv(results_dir / 'summary_table.csv', index=False)

    # Print to console
    print(summary_df.to_string(index=False))
else:
    print('No successful strategies to summarize')
" || echo "[WARNING] Summary generation failed"

# ============================================================================
# CLEANUP
# ============================================================================

echo ""
echo "========================================================================"
echo "CLEANUP"
echo "========================================================================"
echo "[CLEAN] Removing scratch directory: ${SCRATCH_DIR}"
rm -rf "${SCRATCH_DIR}"

# ============================================================================
# FINAL STATUS
# ============================================================================

echo ""
echo "========================================================================"
echo "JOB COMPLETE"
echo "========================================================================"
echo "End time: $(date)"
echo "Results: ${RESULTS_DIR}"
echo "Summary: ${SUMMARY_FILE}"
echo "Logs: ${LOG_DIR}/backtest_*.log"
echo ""

if [ ${#FAILED[@]} -gt 0 ]; then
    echo "⚠️  ${#FAILED[@]} strategies failed - check individual logs"
    exit 1
else
    echo "✓ All ${#SUCCESS[@]} strategies completed successfully"
    exit 0
fi
