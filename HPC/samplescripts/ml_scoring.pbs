#!/bin/bash
# ===== PBS HEADER =====
# XGBoost/RF training - CPU only (no GPU needed)
#PBS -N finsight_ml_scoring
#PBS -A finsight
#PBS -l walltime=24:00:00
# CPU-only node: 48 cores + 384GB RAM (XGBoost needs memory for many backtests)
#PBS -l select=1:ncpus=48:mpiprocs=1:ompthreads=48:mem=384gb
#PBS -j oe

set -eox pipefail

# ===== ENVIRONMENT =====
# Use base Python module (no TensorFlow needed)
TF_MODULE="TensorFlow/2.11.0-foss-2022a-CUDA-11.7.0"
VENV="$HOME/.venvs/finsight-tf211-cuda117"

# ===== PATHS =====
export PROJECT_TAG="finsight"
export WORK="$HOME/projects-sam/FinSight-QuantLab"
export SRC="$WORK/src"
export DATA="$WORK/data"
export OUT_HOME="$WORK/results/ml/pair_scoring"
export LOG_HOME="$WORK/results/logs"
export SCRATCHFORJOB="/scratch/$USER/$PBS_JOBID"
export OUT_SCRATCH="$SCRATCHFORJOB/results/ml/pair_scoring"
export LOG_SCRATCH="$SCRATCHFORJOB/logs"

# ===== CPU CONFIGURATION =====
# XGBoost and joblib will use all cores for parallel backtesting
export OMP_NUM_THREADS=48
export MKL_NUM_THREADS=48
export NUMEXPR_NUM_THREADS=48
export N_JOBS=48

# ===== TRAINING CONFIGURATION =====
# Override via qsub -v MODEL_TYPE=rf MAX_PAIRS=2000 FORMATION_DAYS=180 MIN_OVERLAP=120
export MODEL_TYPE="${MODEL_TYPE:-xgboost}"         # Model: xgboost or rf
export LABEL_METRIC="${LABEL_METRIC:-sharpe}"     # Label: sharpe, returns, max_dd
export MAX_PAIRS="${MAX_PAIRS:-500}"               # Maximum pairs to sample (more = slower)
export TOP_N_PER_STOCK="${TOP_N_PER_STOCK:-10}"    # Pairs per stock (reduces search space)
export FORMATION_DAYS="${FORMATION_DAYS:-180}"     # Formation window (days)
export MIN_OVERLAP="${MIN_OVERLAP:-120}"           # Minimum observations for valid pair

# XGBoost hyperparameters
export XGB_MAX_DEPTH="${XGB_MAX_DEPTH:-6}"
export XGB_N_ESTIMATORS="${XGB_N_ESTIMATORS:-100}"
export XGB_LR="${XGB_LR:-0.1}"

# ===== SETUP =====
mkdir -p "$SCRATCHFORJOB" "$OUT_SCRATCH" "$LOG_SCRATCH"
mkdir -p "$OUT_HOME" "$LOG_HOME"
cd "$SCRATCHFORJOB"

# Live logging
exec > >(stdbuf -oL tee -a "$SCRATCHFORJOB/pbs.live.$PBS_JOBID.out") 2>&1

# Cleanup
cleanup() {
  echo "[CLEANUP] Copying logs from scratch to home..."
  rsync -av "$SCRATCHFORJOB"/pbs.live.$PBS_JOBID.out "$LOG_HOME/" 2>/dev/null || true
  rsync -av "$SCRATCHFORJOB"/train.log "$LOG_HOME/" 2>/dev/null || true
  echo "[CLEANUP] Logs copied to $LOG_HOME"
}
trap cleanup EXIT

echo "========================================"
echo "[ENV] ML Pair Scoring Training"
echo "[ENV] Host: $(hostname)"
echo "[ENV] Job: $PBS_JOBID"
echo "[ENV] Work: $WORK"
echo "[ENV] Scratch Output: $OUT_SCRATCH (fast local I/O)"
echo "[ENV] Final Output: $OUT_HOME (will rsync at end)"
echo "[ENV] Model: $MODEL_TYPE"
echo "[ENV] Label: $LABEL_METRIC"
echo "[ENV] Max Pairs: $MAX_PAIRS"
echo "[ENV] Formation Days: $FORMATION_DAYS"
echo "[ENV] Min Overlap: $MIN_OVERLAP"
echo "[ENV] Top N per Stock: $TOP_N_PER_STOCK"
echo "[ENV] CPU Cores: 48"
echo "========================================"

# ===== MODULES =====
module purge
module load "$TF_MODULE"
echo "[MODULES] Loaded Python"
module list

# ===== VENV =====
# Note: This venv should have xgboost, scikit-learn, pandas, numpy, joblib installed
# Create it before first run:
#   python -m venv ~/.venvs/finsight-tf211-cuda117
#   source ~/.venvs/finsight-tf211-cuda117ml/bin/activate
#   pip install xgboost scikit-learn pandas numpy scipy statsmodels joblib

source "$VENV/bin/activate"
echo "[VENV] Activated: $(which python)"
python --version

# Check key packages
python - <<'PY'
import xgboost as xgb
import sklearn
import pandas as pd
import numpy as np
print(f"[PACKAGES] XGBoost: {xgb.__version__}")
print(f"[PACKAGES] scikit-learn: {sklearn.__version__}")
print(f"[PACKAGES] pandas: {pd.__version__}")
print(f"[PACKAGES] numpy: {np.__version__}")
PY

# ===== STAGE CODE =====
echo "[STAGE] Copying source to scratch..."
rsync -a "$SRC/" "$SCRATCHFORJOB/src/"
rsync -a "$WORK/config.py" "$SCRATCHFORJOB/" 2>/dev/null || true
echo "[STAGE] Complete"

# ===== TRAINING =====
echo "========================================"
echo "[TRAIN] Starting ML Scoring training..."
echo "[TRAIN] Model: $MODEL_TYPE"
echo "[TRAIN] Label metric: $LABEL_METRIC"
echo "[TRAIN] Max pairs: $MAX_PAIRS"
echo "[TRAIN] This will run ~$MAX_PAIRS backtests - may take hours"
echo "========================================"

cd "$SCRATCHFORJOB"

# Create config JSON with environment variables
cat > "$SCRATCHFORJOB/runtime_config.json" <<EOF
{
  "formation_days": ${FORMATION_DAYS},
  "min_overlap": ${MIN_OVERLAP},
  "max_pairs_sample": ${MAX_PAIRS},
  "top_n_per_pair": ${TOP_N_PER_STOCK},
  "label_metric": "${LABEL_METRIC}",
  "model_type": "${MODEL_TYPE}",
  "n_jobs": ${N_JOBS},
  "backtest_entry_z": 2.0,
  "backtest_exit_z": 0.5,
  "backtest_z_window": 60
}
EOF

echo "[CONFIG] Generated runtime config:"
cat "$SCRATCHFORJOB/runtime_config.json"

# Build command - write to scratch (fast local I/O)
TRAIN_CMD="python -u src/ml_train/train_ml_scoring.py \
  --config $SCRATCHFORJOB/runtime_config.json \
  --data-path $DATA/panel_live.parquet \
  --out-dir $OUT_SCRATCH"

# Run training (no GPU, uses all CPUs via joblib)
echo "[TRAIN] Running: $TRAIN_CMD"
$TRAIN_CMD 2>&1 | tee "$SCRATCHFORJOB/train.log"

TRAIN_EXIT_CODE=${PIPESTATUS[0]}

if [ $TRAIN_EXIT_CODE -eq 0 ]; then
  echo "[SUCCESS] Training completed"
else
  echo "[ERROR] Training failed: $TRAIN_EXIT_CODE"
  exit $TRAIN_EXIT_CODE
fi

# ===== STAGE RESULTS BACK TO HOME =====
echo "========================================"
echo "[STAGE] Copying results from scratch to home..."
echo "[STAGE] From: $OUT_SCRATCH"
echo "[STAGE] To: $OUT_HOME"

rsync -av "$OUT_SCRATCH/" "$OUT_HOME/" 2>/dev/null || true
echo "[STAGE] Results copied successfully"

# ===== SUMMARY =====
echo "========================================"
echo "[DONE] ML Scoring training complete!"
echo "[DONE] Results: $OUT_HOME"
echo "[DONE] Logs: $LOG_HOME"
echo "[DONE] Model files:"
ls -lh "$OUT_HOME"/*.{json,pkl} 2>/dev/null || echo "  (no model files)"
echo "[DONE] Feature importance:"
head -10 "$OUT_HOME/feature_importance.csv" 2>/dev/null || echo "  (no feature importance)"
echo "========================================"
