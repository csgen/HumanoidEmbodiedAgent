#!/bin/bash
# ===== PBS HEADER =====
# Job name
#PBS -N finsight_siamese_lstm
# Bill to project
#PBS -A finsight
# Walltime (12 hours - adjust based on your dataset size)
#PBS -l walltime=12:00:00
# Resources: 1 GPU node (A40 + 36 cores + 240GB RAM)
#PBS -l select=1:ncpus=36:mpiprocs=1:ompthreads=36:mem=240gb:ngpus=1
# Merge stdout/stderr
#PBS -j oe

set -eox pipefail

# ===== MODULE AND ENVIRONMENT CONFIGURATION =====
# TensorFlow module (TF 2.11 + CUDA 11.7)
TF_MODULE="TensorFlow/2.11.0-foss-2022a-CUDA-11.7.0"
VENV="$HOME/.venvs/finsight-tf211-cuda117"

# ===== PROJECT PATHS =====
export PROJECT_TAG="finsight"
export WORK="$HOME/projects-sam/FinSight-QuantLab"
export SRC="$WORK/src"
export DATA="$WORK/data"
export OUT_HOME="$WORK/results/deep"
export LOG_HOME="$WORK/results/logs"
export SCRATCHFORJOB="/scratch/$USER/$PBS_JOBID"
export OUT_SCRATCH="$SCRATCHFORJOB/results/deep"
export LOG_SCRATCH="$SCRATCHFORJOB/logs"

# ===== CPU/GPU ENVIRONMENT KNOBS =====
# Threading configuration for TensorFlow + oneDNN
export OMP_NUM_THREADS=36                    # OpenMP threads per op
export TF_NUM_INTRAOP_THREADS=36             # TF parallelism within an op
export TF_NUM_INTEROP_THREADS=4              # TF parallelism across ops
export TF_ENABLE_ONEDNN_OPTS=1               # Use optimized oneDNN kernels
export KMP_BLOCKTIME=0                       # Return threads to pool immediately
export KMP_AFFINITY="granularity=fine,compact,1,0"  # Pack threads onto cores
export TF_FORCE_GPU_ALLOW_GROWTH=true        # Dynamic GPU memory allocation

# Optional: enable XLA JIT compilation (test first, can speed up or slow down)
# export TF_XLA_FLAGS="--tf_xla_auto_jit=2"

# ===== TRAINING CONFIGURATION =====
# Override these via qsub -v or edit here
export EPOCHS="${EPOCHS:-8}"                 # Number of epochs
export BATCH_SIZE="${BATCH_SIZE:-128}"       # Batch size
export LEARNING_RATE="${LR:-0.001}"          # Learning rate
export RESUME="${RESUME:-}"                  # Resume from checkpoint: "" (fresh), "auto", or path

# ===== SETUP =====
mkdir -p "$SCRATCHFORJOB" "$OUT_SCRATCH" "$LOG_SCRATCH"
mkdir -p "$OUT_HOME" "$LOG_HOME"
cd "$SCRATCHFORJOB"

# Stream all job stdout/stderr to live log file
exec > >(stdbuf -oL tee -a "$SCRATCHFORJOB/pbs.live.$PBS_JOBID.out") 2>&1

# Cleanup function to copy logs back even if job exits early
cleanup() {
  echo "[CLEANUP] Copying logs from scratch to home..."
  rsync -av "$SCRATCHFORJOB"/pbs.live.$PBS_JOBID.out "$LOG_HOME/" 2>/dev/null || true
  rsync -av "$SCRATCHFORJOB"/train.log "$LOG_HOME/" 2>/dev/null || true
  echo "[CLEANUP] Logs copied to $LOG_HOME"
}
trap cleanup EXIT

echo "========================================"
echo "[ENV] Siamese LSTM Training"
echo "[ENV] Host: $(hostname)"
echo "[ENV] Job : $PBS_JOBID"
echo "[ENV] Work: $WORK"
echo "[ENV] Scratch Output: $OUT_SCRATCH (fast local I/O)"
echo "[ENV] Final Output: $OUT_HOME (will rsync at end)"
echo "[ENV] Scratch: $SCRATCHFORJOB"
echo "[ENV] TF Module: $TF_MODULE"
echo "[ENV] Python venv: $VENV"
echo "========================================"

# ===== LOAD MODULES =====
module purge
module load "$TF_MODULE"

echo "[MODULES] Loaded TensorFlow module"
module list

# ===== ACTIVATE VIRTUAL ENVIRONMENT =====
source "$VENV/bin/activate"
echo "[VENV] Activated: $(which python)"
python --version

# ===== GPU DIAGNOSTICS =====
echo "========================================"
echo "[GPU] Running nvidia-smi..."
command -v nvidia-smi >/dev/null 2>&1 && nvidia-smi || echo "[GPU] nvidia-smi not found"

echo "[GPU] Testing TensorFlow GPU visibility..."
python - <<'PY'
import tensorflow as tf
gpus = tf.config.list_physical_devices("GPU")
print(f"[GPU] TensorFlow version: {tf.__version__}")
print(f"[GPU] GPUs visible to TF: {gpus}")
if gpus:
    for gpu in gpus:
        print(f"  - {gpu}")
else:
    print("[GPU] WARNING: No GPUs visible to TensorFlow!")
PY
echo "========================================"

# ===== STAGE CODE TO SCRATCH =====
echo "[STAGE] Copying source code to scratch..."
rsync -a "$SRC/" "$SCRATCHFORJOB/src/"
rsync -a "$WORK/config.py" "$SCRATCHFORJOB/" 2>/dev/null || echo "[STAGE] No config.py found (optional)"
echo "[STAGE] Staging complete"

# ===== TRAINING =====
echo "========================================"
echo "[TRAIN] Starting Siamese LSTM training..."
echo "[TRAIN] Epochs: $EPOCHS"
echo "[TRAIN] Batch size: $BATCH_SIZE"
echo "[TRAIN] Learning rate: $LEARNING_RATE"
echo "[TRAIN] Resume: ${RESUME:-fresh}"
echo "========================================"

cd "$SCRATCHFORJOB"

# Build training command - write to scratch (fast local I/O)
TRAIN_CMD="python -u src/ml_train/train_siamese.py \
  --epochs $EPOCHS \
  --batch-size $BATCH_SIZE \
  --learning-rate $LEARNING_RATE \
  --data-path $DATA/panel_live.parquet \
  --out-dir $OUT_SCRATCH"

# Add resume flag if set
if [ -n "$RESUME" ]; then
  if [ "$RESUME" = "auto" ]; then
    TRAIN_CMD="$TRAIN_CMD --resume"
  else
    TRAIN_CMD="$TRAIN_CMD --resume $RESUME"
  fi
fi

# Run training and capture output
echo "[TRAIN] Running: $TRAIN_CMD"
$TRAIN_CMD 2>&1 | tee "$SCRATCHFORJOB/train.log"

TRAIN_EXIT_CODE=${PIPESTATUS[0]}

if [ $TRAIN_EXIT_CODE -eq 0 ]; then
  echo "========================================"
  echo "[SUCCESS] Training completed successfully"
  echo "========================================"
else
  echo "========================================"
  echo "[ERROR] Training failed with exit code: $TRAIN_EXIT_CODE"
  echo "========================================"
  exit $TRAIN_EXIT_CODE
fi

# ===== STAGE RESULTS BACK TO HOME =====
echo "========================================"
echo "[STAGE] Copying results from scratch to home..."
echo "[STAGE] From: $OUT_SCRATCH"
echo "[STAGE] To: $OUT_HOME"

rsync -av "$OUT_SCRATCH/" "$OUT_HOME/" 2>/dev/null || true
echo "[STAGE] Results copied successfully"

# ===== SUMMARY =====
echo "========================================"
echo "[DONE] Job complete!"
echo "[DONE] Results: $OUT_HOME"
echo "[DONE] Logs: $LOG_HOME"
echo "[DONE] Trained models:"
ls -lh "$OUT_HOME"/*.keras 2>/dev/null || echo "  (no checkpoints found)"
echo "[DONE] Training history:"
ls -lh "$OUT_HOME"/*.csv 2>/dev/null || echo "  (no history found)"
echo "========================================"
